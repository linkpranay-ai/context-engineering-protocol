__pycache__/
*.pyc
.pytest_cache/

# md_index.py build artifacts embed the local machine's absolute filesystem
# path in their "root" field - never commit these (see
# starter_kits/context_engineering/context-config.yaml.template).
specs-out/

# mcp_mirror.py build artifacts (ROADMAP items 9/11: MCP-backed What-L1/How-L1
# sourcing) - mirrored .md files and the fetch manifest are regenerated on
# every run, same reasoning as specs-out/ above. mirror/ and
# mcp_mirror_manifest.json cover this repo's own examples/mcp-what-l1-demo/;
# .mcp-mirror/ covers the what_l1.mcp_mirror_path/how_l1.mcp_mirror_path
# subdirectory convention a downstream project's own what_l1.path/how_l1.path
# would use (see context-config.yaml.template).
mirror/
mcp_mirror_manifest.json
.mcp-mirror/

# graphify's own fixed, predictable output directory (graph.json,
# GRAPH_REPORT.md, graph.html, wiki/) - regenerated by `graphify update`/
# `graphify benchmark` on every run, never hand-edited (see
# .github/skills/ult-codegraph/SKILL.md "No normalization step").
graphify-out/
